# SECTION 2 — CAUSAL ENTROPY WINDOW
# ═══════════════════════════════════════════════════════════════════════

class CausalEntropyWindow:
    """
    Uses only previously decoded chunks.
    This lets encoder and decoder reproduce the same state path.
    """

    def __init__(self, W: int = 8, chunk_bytes: int = 5):
        self.W = W
        self.chunk_bytes = chunk_bytes
        self.buffer = []

    def push(self, C: int):
        self.buffer.append(C)
        if len(self.buffer) > self.W:
            self.buffer.pop(0)

    def estimate(self) -> float:
        if not self.buffer:
            return 0.0

        data = b"".join(
            int(c).to_bytes(self.chunk_bytes, "big")
            for c in self.buffer
        )
        return shannon_entropy(data)


