@dataclass
class HRCShard:
    index: int
    lane: int
    phase: int
    generation: int
    residues: List[int]
    data_len: int
    data_hmac: bytes
    shard_hmac: bytes
    n: int
    geometry_dim: int
    W: int
    E_levels: int
    low_shards: int
    high_shards: int
    chunk_bytes: int
    parent_hash: str = "GENESIS"

    def payload_bytes(self) -> bytes:
        header = (
            f"HRC|i={self.index}|lane={self.lane}|phase={self.phase}|"
            f"gen={self.generation}|parent={self.parent_hash}|"
            f"len={self.data_len}|n={self.n}|D={self.geometry_dim}|"
            f"W={self.W}|E={self.E_levels}|"
            f"low={self.low_shards}|high={self.high_shards}|"
            f"cb={self.chunk_bytes}|"
        ).encode()

        body = b"".join(
            int(r).to_bytes(8, "big", signed=False)
            for r in self.residues
        )

        return header + body

    def compute_hmac(self, key: bytes) -> bytes:
        return hmac.new(key, self.payload_bytes(), hashlib.sha256).digest()

    def verify_hmac(self, key: bytes) -> bool:
        return hmac.compare_digest(self.shard_hmac, self.compute_hmac(key))

    def clone(self):
        return copy.deepcopy(self)

    def __repr__(self):
        return (
            f"HRCShard(i={self.index}, lane={self.lane}, "
            f"gen={self.generation}, chunks={len(self.residues)})"
        )


