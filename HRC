def build_prime_table(n: int, E_levels: int, start: int = 2003) -> List[List[int]]:
    """
    PRIME_TABLE[i][e] gives shard i's prime at entropy level e.
    Larger entropy levels get larger primes.
    All entries are unique.
    """
    pool = primes_from(start, n * E_levels + 100)
    return [[pool[i * E_levels + e] for e in range(E_levels)] for i in range(n)]


# ═══════════════════════════════════════════════════════════════════════
# SECTION 5 — HRC CODEC
# ═══════════════════════════════════════════════════════════════════════

class HyperMorphicRegenerativeCorridorCode:
    """
    HyperMorphic Regenerative Corridor Code.

    HCC:
        valid surviving corridor → decode payload

    HRC:
        valid surviving corridor → decode payload → regenerate missing shards
        and optionally migrate into a new representation geometry.

    Corridor validity depends on:
      - shard count
      - CRT capacity
      - lane coverage
      - lane entropy
      - angular spread
      - causal entropy state
    """

    def __init__(
        self,
        n: int = 12,
        geometry_dim: int = 4,
        W: int = 8,
        E_levels: int = 9,
        low_shards: int = 4,
        high_shards: int = 6,
        auth_key: bytes = b"HRC-demo-key-v1",
    ):
        assert n >= geometry_dim >= 2
        assert 2 <= low_shards <= high_shards <= n

        self.n = n
        self.D = geometry_dim
        self.W = W
        self.E_levels = E_levels
        self.low_shards = low_shards
        self.high_shards = high_shards
        self.auth_key = auth_key

        self.lanes = [i % self.D for i in range(n)]
        self.phases = [i // self.D for i in range(n)]

        self.prime_table = build_prime_table(n, E_levels)

        primes0 = sorted(self.prime_table[i][0] for i in range(n))
        prod_low = reduce(lambda a, b: a * b, primes0[:low_shards], 1)

        self.chunk_bytes = max(1, int(math.log(prod_low - 1, 256)))
        self.max_chunk = 256 ** self.chunk_bytes - 1

        if prod_low <= self.max_chunk:
            raise ValueError("Prime table too small for chosen chunk size")

        self.base_table = [
            [safe_base(self.prime_table[i][e]) for e in range(E_levels)]
            for i in range(n)
        ]

        self.inv_cache = {}
        for i in range(n):
            for e in range(E_levels):
                p = self.prime_table[i][e]
                b = self.base_table[i][e]
                self.inv_cache[(b, p)] = modinv(b, p)

        self._subset_cache = {}

        self._verify_invariants()

    # ──────────────────────────────────────────────────────────────────
    # Invariants
    # ──────────────────────────────────────────────────────────────────

    def _verify_invariants(self):
        flat = [p for row in self.prime_table for p in row]

        assert all(is_prime(p) for p in flat), "Non-prime in table"
        assert len(set(flat)) == len(flat), "Duplicate primes"

        for e in range(self.E_levels):
            assert len(set(self.prime_table[i][e] for i in range(self.n))) == self.n

            primes = sorted(self.prime_table[i][e] for i in range(self.n))
            prod = reduce(lambda a, b: a * b, primes[:self.low_shards], 1)
            assert prod > self.max_chunk

        for i in range(self.n):
            for e in range(self.E_levels):
                assert math.gcd(self.base_table[i][e], self.prime_table[i][e]) == 1

    # ──────────────────────────────────────────────────────────────────
    # State and parameters
    # ──────────────────────────────────────────────────────────────────

    def _quantize_entropy(self, H: float) -> int:
        return min(int((H / 8.0) * self.E_levels), self.E_levels - 1)

    def _required_shards(self, e: int) -> int:
        if self.E_levels <= 1:
            return self.low_shards

        return self.low_shards + round(
            (self.high_shards - self.low_shards) * e / (self.E_levels - 1)
        )

    def _required_lanes(self, e: int) -> int:
        if self.E_levels <= 1:
            return min(2, self.D)

        return min(
            self.D,
            2 + round((self.D - 2) * e / (self.E_levels - 1))
        )

    def _required_score(self, e: int) -> float:
        return 0.36 + 0.26 * (e / max(1, self.E_levels - 1))

    def _lambda(self, i: int, pos: int, prime: int, e: int) -> int:
        seed = (
            b"HRC-lambda|"
            + i.to_bytes(2, "big")
            + pos.to_bytes(6, "big")
            + e.to_bytes(2, "big")
        )
        return shake128_int(seed, 8) % prime

    def _params_for(self, i: int, e: int):
        p = self.prime_table[i][e]
        b = self.base_table[i][e]
        inv = self.inv_cache[(b, p)]
        return p, b, inv

    # ──────────────────────────────────────────────────────────────────
    # Chunking
    # ──────────────────────────────────────────────────────────────────

    def _pad(self, data: bytes) -> bytes:
        return data + bytes((-len(data)) % self.chunk_bytes)

    def _to_chunks(self, data: bytes) -> List[int]:
        cb = self.chunk_bytes
        return [
            int.from_bytes(data[i:i + cb], "big")
            for i in range(0, len(data), cb)
        ]

    def _from_chunks(self, chunks: List[int]) -> bytes:
        return b"".join(
            int(c).to_bytes(self.chunk_bytes, "big")
            for c in chunks
        )

    def _data_hmac(self, data: bytes) -> bytes:
        return hmac.new(
            self.auth_key,
            b"HRC-data|" + data,
            hashlib.sha256
        ).digest()

    # ──────────────────────────────────────────────────────────────────
    # Encode
    # ──────────────────────────────────────────────────────────────────

    def encode(
        self,
        data: bytes,
        generation: int = 0,
        parent_hash: str = "GENESIS",
    ) -> List[HRCShard]:

        padded = self._pad(data)
        chunks = self._to_chunks(padded)

        residue_lists = [[] for _ in range(self.n)]
        window = CausalEntropyWindow(self.W, self.chunk_bytes)

        for pos, C in enumerate(chunks):
            H = window.estimate()
            e = self._quantize_entropy(H)

            for i in range(self.n):
                p, b, _ = self._params_for(i, e)
                lam = self._lambda(i, pos, p, e)
                residue_lists[i].append((b * C + lam) % p)

            window.push(C)

        data_hmac = self._data_hmac(data)

        shards = []
        for i in range(self.n):
            s = HRCShard(
                index=i,
                lane=self.lanes[i],
                phase=self.phases[i],
                generation=generation,
                residues=residue_lists[i],
                data_len=len(data),
                data_hmac=data_hmac,
                shard_hmac=b"",
                n=self.n,
                geometry_dim=self.D,
                W=self.W,
                E_levels=self.E_levels,
                low_shards=self.low_shards,
                high_shards=self.high_shards,
                chunk_bytes=self.chunk_bytes,
                parent_hash=parent_hash,
            )
            s.shard_hmac = s.compute_hmac(self.auth_key)
            shards.append(s)

        return shards

    # ──────────────────────────────────────────────────────────────────
    # Corridor metrics
    # ──────────────────────────────────────────────────────────────────

    def corridor_metrics(self, indices: List[int], e: int) -> Dict[str, float]:
        idx = tuple(sorted(indices))
        lanes = [self.lanes[i] for i in idx]
        lane_counts = Counter(lanes)

        lane_coverage = len(lane_counts) / self.D

        n = len(lanes)
        if n == 0:
            lane_entropy = 0.0
            angular_spread = 0.0
        else:
            lane_entropy = -sum(
                (c / n) * math.log2(c / n)
                for c in lane_counts.values()
            ) / math.log2(self.D)

            vx = 0.0
            vy = 0.0

            for lane in lanes:
                theta = 2 * math.pi * lane / self.D
                vx += math.cos(theta)
                vy += math.sin(theta)

            angular_spread = 1.0 - math.sqrt(vx * vx + vy * vy) / n

        moduli = [self.prime_table[i][e] for i in idx]
        product = reduce(lambda a, b: a * b, moduli, 1)

        capacity_bytes = math.log(product, 256) if product > 0 else 0.0
        capacity_margin = capacity_bytes - self.chunk_bytes
        capacity_score = min(
            1.0,
            max(0.0, capacity_margin / max(1, self.chunk_bytes))
        )

        corridor_score = (
            0.38 * lane_coverage
            + 0.30 * lane_entropy
            + 0.22 * angular_spread
            + 0.10 * capacity_score
        )

        return {
            "size": len(idx),
            "lanes": len(lane_counts),
            "lane_coverage": lane_coverage,
            "lane_entropy": lane_entropy,
            "angular_spread": angular_spread,
            "product": product,
            "capacity_bytes": capacity_bytes,
            "capacity_margin": capacity_margin,
            "capacity_score": capacity_score,
            "corridor_score": corridor_score,
            "required_shards": self._required_shards(e),
            "required_lanes": self._required_lanes(e),
            "required_score": self._required_score(e),
        }

    def corridor_valid(self, indices: List[int], e: int) -> bool:
        m = self.corridor_metrics(indices, e)

        return (
            m["size"] >= m["required_shards"]
            and m["lanes"] >= m["required_lanes"]
            and m["product"] > self.max_chunk
            and m["corridor_score"] >= m["required_score"]
        )

    # ──────────────────────────────────────────────────────────────────
    # Shard validation and subset selection
    # ──────────────────────────────────────────────────────────────────

    def _valid_shards(
        self,
        shards: List[Optional[HRCShard]],
        require_hmac: bool = True,
    ) -> List[HRCShard]:

        out = []
        seen = set()

        for s in shards:
            if s is None or not isinstance(s, HRCShard):
                continue

            if s.index in seen:
                continue

            if s.index < 0 or s.index >= self.n:
                continue

            if (
                s.n != self.n
                or s.geometry_dim != self.D
                or s.W != self.W
                or s.E_levels != self.E_levels
                or s.low_shards != self.low_shards
                or s.high_shards != self.high_shards
                or s.chunk_bytes != self.chunk_bytes
            ):
                continue

            if require_hmac and not s.verify_hmac(self.auth_key):
                continue

            out.append(s)
            seen.add(s.index)

        return sorted(out, key=lambda s: s.index)

    def _select_corridor_subset(self, available: List[HRCShard], e: int) -> List[HRCShard]:
        available = sorted(available, key=lambda s: s.index)
        ids = tuple(s.index for s in available)

        key = (ids, e)
        if key in self._subset_cache:
            smap = {s.index: s for s in available}
            return [smap[i] for i in self._subset_cache[key]]

        all_idx = list(ids)

        if self.corridor_valid(all_idx, e):
            self._subset_cache[key] = tuple(all_idx)
            return available

        required = self._required_shards(e)

        best_tuple = None
        best_value = None

        for r in range(required, len(available) + 1):
            for combo in combinations(ids, r):
                if self.corridor_valid(list(combo), e):
                    metrics = self.corridor_metrics(list(combo), e)
                    value = (
                        metrics["corridor_score"],
                        metrics["capacity_margin"],
                    )

                    if best_value is None or value > best_value:
                        best_value = value
                        best_tuple = combo

            if best_tuple is not None:
                break

        if best_tuple is None:
            raise ValueError(
                f"No valid reconstruction corridor at entropy level {e}; "
                f"available={list(ids)}"
            )

        self._subset_cache[key] = tuple(best_tuple)
        smap = {s.index: s for s in available}

        return [smap[i] for i in best_tuple]

    # ──────────────────────────────────────────────────────────────────
    # Decode
    # ──────────────────────────────────────────────────────────────────

    def _reconstruct(
        self,
        available: List[HRCShard],
        data_len: int,
        collect_certificate: bool = False,
    ):
        if not available:
            raise ValueError("No shards")

        n_chunks = len(available[0].residues)

        if any(len(s.residues) != n_chunks for s in available):
            raise ValueError("Mismatched shard lengths")

        window = CausalEntropyWindow(self.W, self.chunk_bytes)
        chunks = []

        cert = {
            "positions": n_chunks,
            "entropy_levels": [],
            "subset_sizes": [],
            "lane_counts": [],
            "corridor_scores": [],
            "capacity_margins": [],
            "selected_subsets_sample": [],
        }

        for pos in range(n_chunks):
            H = window.estimate()
            e = self._quantize_entropy(H)

            selected = self._select_corridor_subset(available, e)
            indices = [s.index for s in selected]
            metrics = self.corridor_metrics(indices, e)

            residues = []
            moduli = []

            for s in selected:
                p, b, inv_b = self._params_for(s.index, e)
                lam = self._lambda(s.index, pos, p, e)
                r = s.residues[pos]

                c = ((r - lam) * inv_b) % p

                residues.append(c)
                moduli.append(p)

            C = crt(residues, moduli)

            if C > self.max_chunk:
                raise ValueError("CRT output outside chunk range")

            chunks.append(C)
            window.push(C)

            if collect_certificate:
                cert["entropy_levels"].append(e)
                cert["subset_sizes"].append(len(indices))
                cert["lane_counts"].append(metrics["lanes"])
                cert["corridor_scores"].append(metrics["corridor_score"])
                cert["capacity_margins"].append(metrics["capacity_margin"])

                if len(cert["selected_subsets_sample"]) < 10:
                    cert["selected_subsets_sample"].append({
                        "pos": pos,
                        "entropy_level": e,
                        "indices": indices,
                        "lanes": [self.lanes[i] for i in indices],
                        "score": round(metrics["corridor_score"], 4),
                        "capacity_margin_bytes": round(metrics["capacity_margin"], 4),
                    })

        raw = self._from_chunks(chunks)
        data = raw[:data_len]

        if not hmac.compare_digest(self._data_hmac(data), available[0].data_hmac):
            raise ValueError("Data HMAC failed")

        if not collect_certificate:
            return data

        cert.update({
            "entropy_level_dist": dict(Counter(cert["entropy_levels"])),
            "subset_size_dist": dict(Counter(cert["subset_sizes"])),
            "lane_count_dist": dict(Counter(cert["lane_counts"])),
            "min_corridor_score": round(min(cert["corridor_scores"]), 5),
            "min_capacity_margin_bytes": round(min(cert["capacity_margins"]), 5),
            "max_required_shards_seen": max(
                self._required_shards(e) for e in cert["entropy_levels"]
            ),
            "max_required_lanes_seen": max(
                self._required_lanes(e) for e in cert["entropy_levels"]
            ),
        })

        return data, cert

    def decode(self, shards: List[Optional[HRCShard]]) -> bytes:
        valid = self._valid_shards(shards, require_hmac=True)

        if len(valid) < self.low_shards:
            raise ValueError(
                f"Need at least {self.low_shards} valid shards; have {len(valid)}"
            )

        return self._reconstruct(valid, valid[0].data_len, collect_certificate=False)

    def decode_with_certificate(self, shards: List[Optional[HRCShard]]):
        valid = self._valid_shards(shards, require_hmac=True)

        if len(valid) < self.low_shards:
            raise ValueError(
                f"Need at least {self.low_shards} valid shards; have {len(valid)}"
            )

        return self._reconstruct(valid, valid[0].data_len, collect_certificate=True)

    # ──────────────────────────────────────────────────────────────────
    # Regeneration / repair
    # ──────────────────────────────────────────────────────────────────

    def repair(
        self,
        shards: List[Optional[HRCShard]],
        replace_all: bool = False,
    ):
        """
        Repair missing or invalid shards in the same geometry.

        If replace_all=False:
            keep valid surviving shards and regenerate only missing/invalid ones.

        If replace_all=True:
            regenerate the whole codeword into a new generation.
        """
        physical = list(shards)
        valid = self._valid_shards(physical, require_hmac=True)

        if len(valid) < self.low_shards:
            raise ValueError("Cannot repair: insufficient valid shards")

        data, decode_cert = self._reconstruct(
            valid,
            valid[0].data_len,
            collect_certificate=True,
        )

        old_generations = [s.generation for s in valid]
        new_generation = max(old_generations) + 1 if old_generations else 1
        parent_hash = self.fingerprint(valid)

        regenerated = self.encode(
            data,
            generation=new_generation,
            parent_hash=parent_hash,
        )

        valid_ids = set(s.index for s in valid)

        repaired = []
        regenerated_indices = []
        kept_indices = []

        for i in range(self.n):
            existing = physical[i] if i < len(physical) else None

            is_valid_existing = (
                existing is not None
                and isinstance(existing, HRCShard)
                and existing.index == i
                and existing.verify_hmac(self.auth_key)
                and i in valid_ids
            )

            if replace_all or not is_valid_existing:
                repaired.append(regenerated[i])
                regenerated_indices.append(i)
            else:
                repaired.append(existing)
                kept_indices.append(i)

        ok = self.decode(repaired) == data

        repair_cert = {
            "mode": "same_geometry_repair",
            "old_geometry": self.geometry_label(),
            "new_geometry": self.geometry_label(),
            "generation_new": new_generation,
            "parent_hash": parent_hash,
            "kept_indices": kept_indices,
            "regenerated_indices": regenerated_indices,
            "valid_before": len(valid),
            "valid_after": len(self._valid_shards(repaired, require_hmac=True)),
            "data_hash": sha256_hex(data),
            "data_hash_preserved": ok,
            "decode_certificate_summary": {
                k: decode_cert[k]
                for k in [
                    "entropy_level_dist",
                    "subset_size_dist",
                    "lane_count_dist",
                    "min_corridor_score",
                    "min_capacity_margin_bytes",
                ]
            },
        }

        return repaired, repair_cert

    def repair_into_new_geometry(
        self,
        shards: List[Optional[HRCShard]],
        new_n: int,
        new_D: int,
        new_W: Optional[int] = None,
        new_E_levels: Optional[int] = None,
        new_low_shards: Optional[int] = None,
        new_high_shards: Optional[int] = None,
    ):
        """
        Decode through the current corridor and re-encode into a new geometry.
        This is the HyperMorphic migration operation.
        """
        data, decode_cert = self.decode_with_certificate(shards)

        new_W = self.W if new_W is None else new_W
        new_E_levels = self.E_levels if new_E_levels is None else new_E_levels

        new_low_shards = (
            new_low_shards
            if new_low_shards is not None
            else max(3, math.ceil(new_n * 0.32))
        )

        new_high_shards = (
            new_high_shards
            if new_high_shards is not None
            else max(new_low_shards, math.ceil(new_n * 0.50))
        )

        new_codec = HyperMorphicRegenerativeCorridorCode(
            n=new_n,
            geometry_dim=new_D,
            W=new_W,
            E_levels=new_E_levels,
            low_shards=new_low_shards,
            high_shards=new_high_shards,
            auth_key=self.auth_key,
        )

        valid = self._valid_shards(shards, require_hmac=True)
        parent_hash = self.fingerprint(valid)

        new_generation = (
            max([s.generation for s in valid]) if valid else 0
        ) + 1

        new_shards = new_codec.encode(
            data,
            generation=new_generation,
            parent_hash=parent_hash,
        )

        ok = new_codec.decode(new_shards) == data

        migration_cert = {
            "mode": "geometry_migration",
            "old_geometry": self.geometry_label(),
            "new_geometry": new_codec.geometry_label(),
            "generation_new": new_generation,
            "parent_hash": parent_hash,
            "data_hash": sha256_hex(data),
            "data_hash_preserved": ok,
            "old_decode_summary": {
                k: decode_cert[k]
                for k in [
                    "entropy_level_dist",
                    "subset_size_dist",
                    "lane_count_dist",
                    "min_corridor_score",
                ]
            },
        }

        return new_codec, new_shards, migration_cert

    # ──────────────────────────────────────────────────────────────────
    # Damage simulation
    # ──────────────────────────────────────────────────────────────────

    def damage_random(
        self,
        shards: List[Optional[HRCShard]],
        count: int,
        seed: Optional[int] = None,
    ):
        rng = random.Random(seed)
        damaged = list(shards)

        indices = list(range(len(damaged)))
        rng.shuffle(indices)

        erased = indices[:count]

        for i in erased:
            damaged[i] = None

        return damaged, erased

    def damage_lanes(
        self,
        shards: List[Optional[HRCShard]],
        lanes_to_erase: List[int],
    ):
        damaged = list(shards)
        erased = []

        lane_set = set(lanes_to_erase)

        for i in range(min(len(damaged), self.n)):
            if self.lanes[i] in lane_set:
                damaged[i] = None
                erased.append(i)

        return damaged, erased

    def corrupt_shards(
        self,
        shards: List[Optional[HRCShard]],
        indices: List[int],
        amount: int = 1,
    ):
        damaged = [
            copy.deepcopy(s) if s is not None else None
            for s in shards
        ]

        for i in indices:
            if i < len(damaged) and damaged[i] is not None and damaged[i].residues:
                for j in range(min(amount, len(damaged[i].residues))):
                    damaged[i].residues[j] ^= 1

        return damaged, indices

    # ──────────────────────────────────────────────────────────────────
    # Utility
    # ──────────────────────────────────────────────────────────────────

    def fingerprint(self, shards: List[HRCShard]) -> str:
        h = hashlib.sha256()

        for s in sorted(shards, key=lambda x: x.index):
            h.update(s.shard_hmac)
            h.update(str(s.index).encode())

        return h.hexdigest()[:24]

    def geometry_label(self) -> str:
        return (
            f"HRC(n={self.n},D={self.D},W={self.W},E={self.E_levels},"
            f"low={self.low_shards},high={self.high_shards},"
            f"cb={self.chunk_bytes})"
        )

    def analyse(self, data: bytes = None) -> Dict:
        info = {
            "geometry": self.geometry_label(),
            "n": self.n,
            "D": self.D,
            "W": self.W,
            "E_levels": self.E_levels,
            "low_shards": self.low_shards,
            "high_shards": self.high_shards,
            "chunk_bytes": self.chunk_bytes,
            "lane_map": {i: self.lanes[i] for i in range(self.n)},
        }

        levels = []
        for e in range(self.E_levels):
            req = self._required_shards(e)
            primes = sorted(self.prime_table[i][e] for i in range(self.n))
            product = reduce(lambda a, b: a * b, primes[:req], 1)

            levels.append({
                "level": e,
                "required_shards": req,
                "required_lanes": self._required_lanes(e),
                "required_score": round(self._required_score(e), 4),
                "prime_range": (primes[0], primes[-1]),
                "capacity_bytes": round(math.log(product, 256), 4),
            })

        info["level_stats"] = levels

        if data is not None:
            padded = self._pad(data)
            chunks = self._to_chunks(padded)
            window = CausalEntropyWindow(self.W, self.chunk_bytes)
            trace = []

            for C in chunks:
                e = self._quantize_entropy(window.estimate())
                trace.append(e)
                window.push(C)

            info["data_entropy_level_dist"] = dict(Counter(trace))

        return info


