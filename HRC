def run_hrc_tests():
    print("╔══════════════════════════════════════════════════════════════════════╗")
    print("║  HyperMorphic Regenerative Corridor Code — Test Suite               ║")
    print("╚══════════════════════════════════════════════════════════════════════╝")

    hrc = HyperMorphicRegenerativeCorridorCode()
    results = []

    def section(title):
        print("\n" + "─" * 78)
        print(" ", title)
        print("─" * 78)

    def check(name, ok, note=""):
        results.append(bool(ok))
        icon = "✅" if ok else "❌"
        print(f"  {icon} {name:<68} {note}")

    # 1. Basic roundtrip
    section("1. BASIC ENCODE / DECODE")

    cases = [
        ("short", b"HyperMorphic Regenerative Corridor Codes"),
        ("zeros", bytes(512)),
        ("random 2KB", os.urandom(2048)),
        ("pattern", b"HRC-" * 700),
    ]

    for name, data in cases:
        shards = hrc.encode(data)
        recovered = hrc.decode(shards)
        check(f"Roundtrip: {name}", recovered == data, f"len={len(data)}")

    # 2. Same-geometry repair
    section("2. SAME-GEOMETRY REPAIR")

    data = os.urandom(2048)
    shards = hrc.encode(data)

    damaged, erased = hrc.damage_random(shards, 4, seed=42)
    repaired, cert = hrc.repair(damaged)

    check(
        "Repair regenerates erased shards",
        set(erased).issubset(set(cert["regenerated_indices"])),
        f"erased={erased}, regenerated={cert['regenerated_indices']}",
    )

    check(
        "Repaired full codeword decodes",
        hrc.decode(repaired) == data,
        f"valid_after={cert['valid_after']}",
    )

    check(
        "Repair certificate preserves data hash",
        cert["data_hash_preserved"],
        cert["data_hash"],
    )

    # 3. Corruption repair
    section("3. CORRUPTION REPAIR")

    data = b"corruption repair payload" * 200
    shards = hrc.encode(data)

    corrupted, bad = hrc.corrupt_shards(shards, [0, 5])
    repaired, cert = hrc.repair(corrupted)

    check(
        "Tampered shards get regenerated",
        set(bad).issubset(set(cert["regenerated_indices"])),
        f"bad={bad}, regenerated={cert['regenerated_indices']}",
    )

    check(
        "Repair after corruption decodes",
        hrc.decode(repaired) == data,
    )

    # 4. Geometry migration
    section("4. GEOMETRY MIGRATION")

    data = os.urandom(4096)
    shards = hrc.encode(data)

    damaged, erased = hrc.damage_random(shards, 3, seed=7)

    new_codec, new_shards, migration_cert = hrc.repair_into_new_geometry(
        damaged,
        new_n=16,
        new_D=8,
        new_low_shards=5,
        new_high_shards=8,
    )

    check(
        "Migration produces new geometry",
        new_codec.n == 16 and new_codec.D == 8,
        migration_cert["new_geometry"],
    )

    check(
        "Migrated shards decode under new geometry",
        new_codec.decode(new_shards) == data,
    )

    check(
        "Migration certificate preserves hash",
        migration_cert["data_hash_preserved"],
        migration_cert["data_hash"],
    )

    # 5. Invalid corridor rejection
    section("5. INVALID CORRIDOR SHOULD FAIL")

    high_entropy = os.urandom(2048)
    shards = hrc.encode(high_entropy)

    # Same count as a valid high-entropy corridor, but clustered into only lanes 0/1.
    keep = [0, 1, 4, 5, 8, 9]
    clustered = [shards[i] if i in keep else None for i in range(hrc.n)]

    try:
        hrc.decode(clustered)
        check("High entropy clustered corridor rejected", False, "unexpected decode")
    except Exception as ex:
        check("High entropy clustered corridor rejected", True, str(ex)[:80])

    # 6. Repeated regeneration cycles
    section("6. REPEATED REGENERATION CYCLES")

    data = os.urandom(2048)
    shards = hrc.encode(data)

    ok = True
    last_cert = None

    for gen in range(20):
        damaged, erased = hrc.damage_random(shards, 4, seed=100 + gen)

        try:
            shards, last_cert = hrc.repair(damaged)

            if hrc.decode(shards) != data:
                ok = False
                break

        except Exception as ex:
            print("cycle fail", gen, ex)
            ok = False
            break

    check(
        "20 damage → repair → verify cycles survived",
        ok,
        f"last_generation={last_cert['generation_new'] if last_cert else None}",
    )

    # Summary
    section("SUMMARY")

    passed = sum(results)
    total = len(results)

    print(f"  RESULTS: {passed}/{total} passed")

    if passed == total:
        print("  ✅ ALL PASS — HRC primitive validated")
    else:
        print(f"  ❌ {total - passed} failures")

    return passed == total


